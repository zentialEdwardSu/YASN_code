<Window x:Class="YASN.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YASN"
        mc:Ignorable="d"
        Title="YASN - Note Manager" 
        Height="500" 
        Width="600"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <local:BoolToActionConverter x:Key="BoolToActionConverter"/>
        <local:BoolToButtonColorConverter x:Key="BoolToButtonColorConverter"/>
    </Window.Resources>
    
    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="20,15">
            <TextBlock Text="YASN - Yet Another Sticky Notes" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" 
                    Background="White" 
                    BorderBrush="#CCC" 
                    BorderThickness="1" 
                    CornerRadius="5"
                    Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="WindowListPanel">
                        <TextBlock Text="All Notes" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>
                        
                        <ListView x:Name="WindowListView"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" 
                                            Margin="0,2" 
                                            Padding="10,8"
                                            CornerRadius="4"
                                            BorderBrush="#DEE2E6"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBox Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                         FontWeight="SemiBold"
                                                         FontSize="14"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         Padding="0"
                                                         Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="12" 
                                                               Foreground="#666"
                                                               Margin="0,0,10,0">
                                                        <Run Text="Level:"/>
                                                        <Run Text="{Binding Level, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" 
                                                               Foreground="{Binding IsOpen, Converter={StaticResource BoolToColorConverter}}"
                                                               FontWeight="SemiBold">
                                                        <Run Text="{Binding StatusText, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="{Binding IsOpen, Converter={StaticResource BoolToActionConverter}}" 
                                                        Click="ToggleWindow_Click"
                                                        Tag="{Binding}"
                                                        Background="{Binding IsOpen, Converter={StaticResource BoolToButtonColorConverter}}"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Padding="10,5"
                                                        Margin="5,0"
                                                        Cursor="Hand"
                                                        FontSize="12"/>
                                                <Button Content="Delete" 
                                                        Click="DeleteNote_Click"
                                                        Tag="{Binding}"
                                                        Background="#E74C3C"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Padding="10,5"
                                                        Cursor="Hand"
                                                        FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        
                        <TextBlock x:Name="NoWindowsText"
                                   Text="No notes yet. Create one using the buttons on the right."
                                   Foreground="#999"
                                   TextWrapping="Wrap"
                                   Margin="0,20,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" 
                    Background="White" 
                    BorderBrush="#CCC" 
                    BorderThickness="1" 
                    CornerRadius="5"
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="Create Note" 
                               FontSize="14" 
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>
                    
                    <Button Content="Top Window" 
                            Padding="12,8" 
                            Margin="0,0,0,10"
                            Click="CreateTopWindow_Click"
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"/>
                    
                    <Button Content="Normal Window" 
                            Padding="12,8" 
                            Margin="0,0,0,10"
                            Click="CreateNormalWindow_Click"
                            Background="#95A5A6"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"/>
                    
                    <Button Content="Bottom Window" 
                            Padding="12,8" 
                            Margin="0,0,0,10"
                            Click="CreateBottomWindow_Click"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"/>
                    
                    <Separator Margin="0,10"/>
                    
                    <Button Content="Refresh List" 
                            Padding="12,8" 
                            Margin="0,10,0,10"
                            Click="RefreshList_Click"
                            Background="#34495E"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"/>
                    
                    <Button Content="Settings" 
                            Padding="12,8" 
                            Margin="0,0,0,10"
                            Click="Settings_Click"
                            Background="#9B59B6"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"/>
                    
                    <Button Content="Hide to Tray" 
                            Padding="12,8" 
                            Margin="0,0,0,0"
                            Click="HideToTray_Click"
                            Background="#7F8C8D"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
