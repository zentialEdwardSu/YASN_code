<Window x:Class="YASN.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:settings="clr-namespace:YASN.App.Settings"
        mc:Ignorable="d"
        Title="Settings - YASN"
        Height="520"
        Width="780"
        WindowStartupLocation="CenterOwner"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation -->
        <Border Grid.Row="0"
                Grid.Column="0"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="1">
            <StackPanel>
                <ListBox x:Name="NavList"
                         ItemsSource="{Binding Modules}"
                         DisplayMemberPath="Title"
                         SelectedIndex="0"
                         SelectionChanged="NavList_SelectionChanged"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="16,10"/>
                            <Setter Property="Margin" Value="8,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#34495E"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="NavBorder"
                                                CornerRadius="6"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter Margin="10,6"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="NavBorder" Property="Background" Value="#E8F4FD"/>
                                                <Setter Property="Foreground" Value="#1B75BB"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="NavBorder" Property="Background" Value="#F2F6F9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer x:Name="ModuleScrollViewer"
                      Grid.Row="0"
                      Grid.Column="1"
                      Margin="15,10,10,10"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ModuleItemsControl" ItemsSource="{Binding Modules}" Margin="0 0 15 0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type settings:SettingModule}">
                            <StackPanel>
                                <Grid Margin="0 0 0 2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Height="1" Background="#2C3E50" VerticalAlignment="Center" Margin="0 0 8 0 "/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#2C3E50"/>
                                    <Border Grid.Column="2" Height="1" Background="#2C3E50" VerticalAlignment="Center" Margin="8 0 0 0 "/>
                                </Grid>

                                <TextBlock Text="{Binding Description}"
                                           FontSize="12"
                                           Foreground="#7F8C8D"
                                           Margin="0,4,0,16"
                                           TextWrapping="Wrap"/>

                                <ItemsControl ItemsSource="{Binding Fields}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type settings:SettingField}">
                                            <Border BorderBrush="#EEE"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0,5,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="220"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#34495E"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="11"
                                                                   Foreground="#7F8C8D"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0"/>
                                                    </StackPanel>

                                                    <!-- Toggle -->
                                                    <ui:ToggleSwitch Grid.Column="1"
                                                                     VerticalAlignment="Center"
                                                                     IsOn="{Binding BoolValue, Mode=TwoWay}"
                                                                     OnContent=""
                                                                     OffContent="">
                                                        <ui:ToggleSwitch.Style>
                                                            <Style TargetType="{x:Type ui:ToggleSwitch}"
                                                                   BasedOn="{StaticResource {x:Type ui:ToggleSwitch}}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="{x:Static settings:SettingFieldType.Toggle}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:ToggleSwitch.Style>
                                                    </ui:ToggleSwitch>
                                                    <!-- Text -->
                                                    <Grid Grid.Column="1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBox Grid.Column="0"
                                                                 VerticalAlignment="Center"
                                                                 Padding="8"
                                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                            <TextBox.Style>
                                                                <Style TargetType="TextBox"
                                                                       BasedOn="{StaticResource {x:Type TextBox}}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding FieldType}" Value="{x:Static settings:SettingFieldType.Text}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBox.Style>
                                                        </TextBox>

                                                        <Button Grid.Column="1"
                                                                Content="娴忚..."
                                                                Width="64"
                                                                Height="28"
                                                                VerticalAlignment="Center"
                                                                Margin="6,0,0,0"
                                                                Padding="6,0"
                                                                Tag="{Binding}"
                                                                Click="BrowseDataDirectoryButton_Click"
                                                                Visibility="Collapsed">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding EnableFolderBrowse}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Grid>
                                                    <!-- Select -->
                                                    <ComboBox Grid.Column="1"
                                                              VerticalAlignment="Center"
                                                              Padding="6,4"
                                                              ItemsSource="{Binding Options}"
                                                              DisplayMemberPath="Label"
                                                              SelectedValuePath="Value"
                                                              SelectedValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                        <ComboBox.Style>
                                                            <Style TargetType="ComboBox"
                                                                   BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="{x:Static settings:SettingFieldType.Select}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ComboBox.Style>
                                                    </ComboBox>
                                                    <!-- Password -->
                                                    <PasswordBox x:Name="PasswordBox"
                                                                 Grid.Column="1"
                                                                 VerticalAlignment="Center"
                                                                 Padding="8"
                                                                 PasswordChanged="PasswordBox_PasswordChanged"
                                                                 Loaded="PasswordBox_Loaded">
                                                        <PasswordBox.Style>
                                                            <Style TargetType="PasswordBox"
                                                                   BasedOn="{StaticResource {x:Type PasswordBox}}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="{x:Static settings:SettingFieldType.Password}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </PasswordBox.Style>
                                                    </PasswordBox>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Margin="0,12,0,0">
                                    <ItemsControl ItemsSource="{Binding Actions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type settings:SettingAction}">
                                                <Button Content="{Binding Label}"
                                                        Tag="{Binding}"
                                                        Click="ActionButton_Click"
                                                        Margin="0,0,10,8"
                                                        Padding="14,8"
                                                        HorizontalAlignment="Left"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="{Binding Status}"
                                               FontSize="12"
                                               Foreground="#1B75BB"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
