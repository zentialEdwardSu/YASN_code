## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# User-specific files
*.user
*.userosscache
*.suo
*.sln.docstates
*.vspscc
*.vssscc
*.rsuser

# Visual Studio 2022+ workspace
.vs/

# Build artifacts
*.exe
*.dll
*.pdb
*.cache
*.ilk
*.log
*.obj
*.tmp
*.bak

# NuGet
*.nupkg
*.snupkg
packages/
# If using PackageReference, comment out above line
*.nuget.props
*.nuget.targets

# Azure build output
[Aa]rtifacts/

# Rider / JetBrains IDE
.idea/
*.sln.iml

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml

# NCrunch
_NCrunch_*
.*crunch*.local.xml

# Windows image cache files
Thumbs.db
ehthumbs.db

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows Installer files
*.cab
*.msi
*.msm
*.msp

# WPF specific (generated resources, temporary XAML files)
*.g.*
*.g.i.*
*.baml
*.xaml.vb

# Local app settings
appsettings.Development.json
secrets.json

# Publish output
publish/
dist/
out/

# DotCover
.idea.DotSettings.user

# Others
*.dbmdl
*.jfm
*.pfx
*.snk

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# TFS
$tf/

# VS Code settings (optional)
.vscode/

# Rider settings (optional)
.idea/

# Logs and crash dumps
*.stackdump
*.dmp
*.log

# Local environment files
.env
.env.*

# Mac OS / Linux (if cross-platform dev)
.DS_Store
*.swp
*.swo

.dotnet_cli/
.dotnet/